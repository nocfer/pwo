    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-check": "^4.5.3",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.0"
