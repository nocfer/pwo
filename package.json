{
  "name": "progressive-workout",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "compile": "npx tsc --noEmit",
    "lint": "expo lint",
    "lint:fix": "prettier --write . && eslint ./components ./lib ./__tests__ ./app ./context ./hooks ./types ./theme --ext .ts,.tsx,.js,.json --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "deploy": "gh-pages --nojekyll -d dist",
    "predeploy": "expo export -p web"
  },
